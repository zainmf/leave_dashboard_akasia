# ---- Free-tier setup (Supabase + Render) ----------------------------------
PORT=8080

# Supabase → Project Settings → Database → Connection string (URI). Requires SSL.
# Use the "Session" pooler string (port 5432) for a long-running server like Render.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Auth — generate a long random value (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me
TOKEN_TTL=8h

# Company conventions
EMAIL_DOMAIN=akasia365mc.com
PW_SUFFIX=Akasia365mc

# Supabase Storage (create a PRIVATE bucket named "attachments")
# Settings → API → Project URL and the service_role key (keep server-side only!)
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=attachments

# CORS — your deployed front-end origin (e.g. https://your-app.netlify.app)
CORS_ORIGIN=http://localhost:5173

# ---- Alternative: self-hosted Postgres (ignored if DATABASE_URL is set) ----
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=timeoff
# DB_USER=app
# DB_PASSWORD=changeme
